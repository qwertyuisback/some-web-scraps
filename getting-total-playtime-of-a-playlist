# Import necessary libraries
from selenium import webdriver

# Set up the WebDriver (Chrome)
driver = webdriver.Chrome()  # Requires ChromeDriver or Google Chrome installed
driver.get("https://www.youtube.com/playlist?list=PLh5DDeppeM8u9jv5_bU89zRzxP_lY5dUm") #Write the playlist link here
page_source = driver.page_source

#Waiting for the page to load
from selenium.webdriver.support.ui import WebDriverWait
WebDriverWait(driver, timeout=10)

#Scrolling the page until the end:
from selenium.webdriver.common.by import By
from selenium.webdriver.common.keys import Keys
import time
body=driver.find_element(By.TAG_NAME ,"body")
#find the number of videos in the playlist by its specified class
noofvideos_element=driver.find_elements(By.CLASS_NAME,"yt-core-attributed-string.yt-content-metadata-view-model__metadata-text.yt-core-attributed-string--white-space-pre-wrap.yt-core-attributed-string--link-inherit-color")
noofvideos=noofvideos_element[1].text
#Remove the string from noofvideos and convert it to an integer
noofvideos=int(noofvideos.split()[0])
print("Number of videos in the playlist:",noofvideos)

#Scroll the page "number of videos" times. We do this to make sure that all videos are loaded on the page,otherwise we may miss some videos and cannot include them in the total playtime calculation.
for _ in range(noofvideos):  
    body.send_keys(Keys.PAGE_DOWN)
    time.sleep(0.5)  # Waiting time between scrollling. without this break scrolling doesn't work properly
print("Scrolling completed. Please don't forget to control the page after this process.")

# Find all lengths by its specified class
time_strings=[] #A list to collect lengths extracted via Selenium
# Extract and print the text from each element
elements = driver.find_elements(By.CLASS_NAME,"yt-badge-shape__text")#'badge-shape-wiz__text')
print("number of elements found:",len(elements))
print("elements:",elements)
for element in elements:
    time_strings.append(element.text)
    print(element.text) 

driver.quit()

if "CANLI" in time_strings :  #If the video is live, we can't calculate its length, so we will ignore it.
    time_strings.remove("CANLI")
if "LIVE" in time_strings :  #If the video is live, we can't calculate its length, so we will ignore it.
    time_strings.remove("LIVE")
if '' in time_strings:  #If there is an empty string in the list, we will ignore it.
    time_strings.remove('')

print("number of video lengths found:",len(time_strings))
print("time_strings:",time_strings)

from datetime import timedelta
# Function to convert time strings to timedelta
def parse_time_string(time_str):
    parts = time_str.split(":")
    if len(parts) == 2:  # Format: MM:SS
        minutes, seconds = map(int, parts)
        return timedelta(minutes=minutes, seconds=seconds)
    elif len(parts) == 3:  # Format: HH:MM:SS
        hours, minutes, seconds = map(int, parts)
        return timedelta(hours=hours, minutes=minutes, seconds=seconds)
    else:
        raise ValueError(f"Invalid time format: {time_str}")

# Calculate the total time
total_time = sum((parse_time_string(t) for t in time_strings), timedelta())

# Print the total time in HH:MM:SS format
total_hours, remainder = divmod(total_time.total_seconds(), 3600)
total_minutes, total_seconds = divmod(remainder, 60)
print(f"Total Time: {int(total_hours):02}:{int(total_minutes):02}:{int(total_seconds):02}")

