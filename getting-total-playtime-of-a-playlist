#Scrolling the page until the end:
from selenium.webdriver.common.by import By
from selenium.webdriver.common.keys import Keys
import time
body=driver.find_element(By.TAG_NAME ,"body")
#find the number of videos in the playlist by its specified class
noofvideos_element=driver.find_elements(By.CLASS_NAME,"yt-core-attributed-string.ytContentMetadataViewModelMetadataText.yt-core-attributed-string--white-space-pre-wrap.yt-core-attributed-string--link-inherit-color")
print("number of elements found:",len(noofvideos_element))
# print("noofvideos_element:",noofvideos_element)
for element in noofvideos_element:
    print(f"Element text: {element.text}")
noofvideos=noofvideos_element[1].text
print("noofvideos:",noofvideos)
#Remove the string from noofvideos and convert it to an integer
noofvideos=int(noofvideos.split()[0])
print("Number of videos in the playlist:",noofvideos)

#Scroll the page "number of videos" times. We do this to make sure that all videos are loaded on the page,otherwise we may miss some videos and cannot include them in the total playtime calculation.
for _ in range(noofvideos):  
    body.send_keys(Keys.PAGE_DOWN)
