print("number of video lengths found overall:",len(time_strings_og))
time_strings = [t for t in time_strings_og if t]  # Remove empty strings from the list
print("time_strings after deletion of empty strings:",len(time_strings))
print("time_strings list after deletion of empty strings:",time_strings)

calculate_from=125 #if we want to calculate the total playtime starting from a specific video, we can specify its index here. For example, if we want to calculate the total playtime starting from the second video, we can set this variable to 2. By default, it is set to 1, which means that we will calculate the total playtime of all videos in the playlist. 
time_strings_sp = time_strings[calculate_from-1:]  # Keep only the time strings starting from the specified index
print("time_strings from a specific index:",time_strings_sp)

if "CANLI" in time_strings_sp :  #If the video is live, we can't calculate its length, so we will ignore it.
    time_strings_sp.remove("CANLI")
if "LIVE" in time_strings_sp :  #If the video is live, we can't calculate its length, so we will ignore it.
    time_strings_sp.remove("LIVE")
if '' in time_strings_sp:  #If there is an empty string in the list, we will ignore it.
    time_strings_sp.remove('')


from datetime import timedelta
# Function to convert time strings to timedelta
def parse_time_string(time_str):
    parts = time_str.split(":")
    if len(parts) == 2:  # Format: MM:SS
        minutes, seconds = map(int, parts)
        return timedelta(minutes=minutes, seconds=seconds)
    elif len(parts) == 3:  # Format: HH:MM:SS
        hours, minutes, seconds = map(int, parts)
        return timedelta(hours=hours, minutes=minutes, seconds=seconds)
    else:
        raise ValueError(f"Invalid time format: {time_str}")

# Calculate the total time
total_time = sum((parse_time_string(t) for t in time_strings_sp), timedelta())

# Print the total time in HH:MM:SS format
total_hours, remainder = divmod(total_time.total_seconds(), 3600)
total_minutes, total_seconds = divmod(remainder, 60)
print(f"Total Time: {int(total_hours):02}:{int(total_minutes):02}:{int(total_seconds):02}")



